# BishtAipanArt - Environment Configuration
# Copy this file to .env and fill in your values

# ===== TELEGRAM NOTIFICATIONS (FREE - RECOMMENDED) =====
# Get notified on Telegram when someone places an order or contacts you.
#
# SETUP STEPS:
# 1. Open Telegram and search for "BotFather"
# 2. Send: /newbot
# 3. Choose a name (e.g., "BishtAipanArt")
# 4. Choose a username ending in "bot" (e.g., "bisht_aipan_bot")
# 5. BotFather gives you a token - paste it below
# 6. Open your bot on Telegram and send any message (e.g., "Hi")
# 7. Visit: https://api.telegram.org/botYOUR_TOKEN/getUpdates
# 8. Look for "chat":{"id":123456789} - that's your chat ID
#
VITE_TELEGRAM_BOT_TOKEN=
VITE_TELEGRAM_CHAT_ID=

# ===== WEBSITE INFO =====
VITE_SITE_URL=https://bishtaipanart.com
VITE_CONTACT_EMAIL=vijaybishta2004@gmail.com
VITE_CONTACT_PHONE=+919045236987

# ===== PAYMENT GATEWAY (Optional for production) =====
# Razorpay integration for processing payments
